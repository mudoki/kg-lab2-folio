# ------------------------------------------------------------
# INTERESTS
# ------------------------------------------------------------

mkd:InterestKaraoke a mkv:MusicInterest ;
    mkv:interestLabel "Karaoke" ;
    rdfs:comment """The practice of singing along to recorded music with on-screen lyrics.
    Particularly compelling when the song selection includes late 1970s disco and lyrics 
    can being sang in gibberish for maximum enjoyment. The intersection of this interest 
    with mkd:StayinAlive is not a coincidence. Singing drunk can be allowed."""@en .

mkd:InterestMoons a mkv:CelestialInterest ;
    mkv:interestLabel "Natural Satellites" ;
    rdfs:comment """Here, natural satellites orbiting planets 
    and other bodies. Particular focus on ocean worlds: Europa and Ganymede 
    (Jupiter system), Titan and Enceladus (Saturn system). The question of 
    whether subsurface liquid water can sustain life is the underlying motivation."""@en .

mkd:InterestExoplanets a mkv:CelestialInterest ;
    mkv:interestLabel "Exoplanets and Habitable Zones" ;
    rdfs:comment """Planets orbiting stars other than the Sun. Of specific interest: 
    planets in the habitable zone of their host star, where liquid water 
    could exist on the surface. Proxima Centauri b is the most immediately 
    compelling example - the nearest star system to Earth hosts a potentially 
    habitable world."""@en .

mkd:InterestSemanticWeb a mkv:KnowledgeInterest ;
    mkv:interestLabel "Semantic Web, Linked Data and Vocabularies" ;
    rdfs:comment """The idea that data on the web can be structured, linked, and made 
    machine-readable using RDF, RDFS, OWL, and SPARQL, among others. The fact that this 
    interest is itself described in a vocabulary built from that same stack 
    is either a satisfying recursion or a mild epistemological problem. 
    Possibly both."""@en .
    
mkd:InterestEtymology a mkv:Interest ;
    mkv:interestLabel "Etymology" ;
    rdfs:comment """The study of the origin and historical development of words. 
    For thos who enjoy continuously living in frustration why
    algorithm and logarithm have very different origins, knowing that they share the math domain, and that does not mean that
    they should be explained the same way. I love words, but I hate them too"""@en .

# ------------------------------------------------------------
# THE SONG - Stayin' Alive
# Wikidata Q1352181, as specified
# ------------------------------------------------------------

mkd:StayinAlive a mkv:Song ;
    mkv:songTitle "Stayin' Alive" ;
    mkv:composedBy "Barry Gibb, Robin Gibb, Maurice Gibb" ;
    mkv:performedBy "Bee Gees" ;
    mkv:releasedIn "1977"^^xsd:gYear ;
    rdfs:comment """Written by the Gibb brothers and performed by the Bee Gees, 
    released in 1977 as part of the Saturday Night Fever soundtrack. 
    The opening bass line is among the most recognisable in popular music. 
    The song's tempo - approximately 103 beats per minute - 
    is frequently cited in medical literature as an appropriate rhythm 
    for performing CPR chest compressions, meaning it is simultaneously 
    a disco classic and a public health resource. 
    An ideal karaoke selection: high recognisability, 
    forgiving vocal range, and a chorus that an entire room 
    will join uninvited. Shout out to Michael Scott for mistaking it with I Will Survive - a 
    song in a similar spirit, but not sure if a victim will actually survive with chest compressions
    to that rhythm."""@en ;
    owl:sameAs wd:Q1352181 .

# ------------------------------------------------------------
# CELESTIAL BODIES
# owl:sameAs links to Wikidata ensure nodes are referenceable
# ------------------------------------------------------------

mkd:Jupiter a mkv:Planet ;
    rdfs:label "Jupiter"@en ;
    rdfs:comment """The largest planet in the solar system, fifth from the Sun and  a gas giant with a mass 
    more than twice that of all other planets combined. Host to at least 95 known 
    moons, including the four large Galilean moons discovered by Galileo in 1610."""@en ;
    mkv:distanceFromSunAU "5.2"^^xsd:decimal ;
    owl:sameAs wd:Q319 .

mkd:Saturn a mkv:Planet ;
    rdfs:label "Saturn"@en ;
    rdfs:comment """The sixth planet from the Sun, a gas giant defined by its spectacular 
    ring system. Hosts 146 known moons. Can you imagine staring at the sky in this planet?
    Besides the stars, so many moons! Fun concepts of nights and days here, right?"""@en ;
    mkv:distanceFromSunAU "9.58"^^xsd:decimal ;
    owl:sameAs wd:Q193 .

mkd:Europa a mkv:Moon ;
    rdfs:label "Europa"@en ;
    rdfs:comment """The sixth-closest moon of Jupiter and the smallest of the four 
    Galilean moons. Slightly smaller than Earth's Moon, it has a smooth, 
    bright icy surface with very few craters, suggesting a geologically young 
    and active surface."""@en ;
    mkv:orbits mkd:Jupiter ;
    owl:sameAs wd:Q3143 .

mkd:Titan a mkv:Moon ;
    rdfs:label "Titan"@en ;
    rdfs:comment """The largest moon of Saturn and the second-largest natural satellite 
    in the solar system, larger than the planet Mercury."""@en ;
    mkv:orbits mkd:Saturn ;
    owl:sameAs wd:Q2565 .

mkd:Ganymede a mkv:Moon ;
    rdfs:label "Ganymede"@en ;
    rdfs:comment """The largest moon in the solar system, orbiting Jupiter. 
    Larger than the planet Mercury, though less massive. 
    The only moon known to generate its own magnetic field, 
    creating auroras near its poles."""@en ;
    mkv:orbits mkd:Jupiter ;
    owl:sameAs wd:Q3169 .

mkd:Io a mkv:Moon ;
    rdfs:label "Io"@en ;
    rdfs:comment """The innermost of the four Galilean moons of Jupiter and 
    the most volcanically active body in the solar system."""@en ;
    mkv:orbits mkd:Jupiter ;
    owl:sameAs wd:Q3123 .

mkd:ProximaCentauri a mkv:Star ;
    rdfs:label "Proxima Centauri"@en ;
    rdfs:comment """A red dwarf star and the closest known star to the Sun
    Exists in the constellation Centaurus. 
    Too faint to be seen with the naked eye. Part of the Alpha Centauri triple 
    star system. Hosts at least two known exoplanets, including Proxima Centauri b."""@en ;
    owl:sameAs wd:Q14266 .

mkd:ProximaCentauriB a mkv:Planet ;
    rdfs:label "Proxima Centauri b"@en ;
    rdfs:comment """An extrasolar orbiting Proxima Centauri, the nearest star to the Sun. 
    Discovered in 2016. It orbits within the habitable zone of its host star - 
    the range of distances where liquid water could exist on a surface - 
    completing one orbit every 11.2 Earth days. Its prospects for habitability 
    are debated: the planet likely faces intense ultraviolet and X-ray radiation 
    from stellar flares, and may be tidally locked, with one hemisphere in 
    permanent day and the other in permanent night. Nonetheless it remains 
    the closest potentially habitable world to Earth."""@en ;
    mkv:orbits mkd:ProximaCentauri ;
    owl:sameAs wd:Q26692445 .

