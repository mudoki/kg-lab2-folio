    a mkv:Student, mkv:KnowledgeGraphsResearcher, mkv:EarlyYearsEducator ;
    mkv:name "Marlin Kisia" ;
    mkv:identifier "567890" ;
    mkv:email "marlinkisia@email.com" ;
    mkv:yearOfStudy 1 ;
    mkv:memberOf mkd:GhentUniversity ;
    mkv:worksFor mkd:SunflowerKindergarten ;
    mkv:hasLabInstructor mkd:ElsDeVleeschauwer ;
    mkv:hasPeer mkd:SeppeSantens, mkd:WardDeMuynck,
                mkd:ThijsDhulster, mkd:OliverDeMeyst ;
    mkv:hasInterest mkd:InterestKaraoke, mkd:InterestEtymology, mkd:InterestMoons,
                    mkd:InterestExoplanets, mkd:InterestSemanticWeb ;
    mkv:observes mkd:Europa, mkd:Titan, mkd:Ganymede,
                 mkd:Io, mkd:ProximaCentauriB, mkd:ProximaCentauri ;
